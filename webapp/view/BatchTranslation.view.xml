<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:u="sap.ui.unified"
	controllerName="doctranslationv1.controller.BatchTranslation">
	<App>
		<pages>
			<Page>
				<customHeader>
					<Bar>
						<contentLeft>
							<Button icon="sap-icon://nav-back" press="navBack"/>
						</contentLeft>
						<contentMiddle >
							<Title text="GenAI Document Translation Agent for SAP"></Title>
						</contentMiddle>
						<contentRight>
							<Image src="images/whitelogocg.png" width="8.7rem"/>
						</contentRight>
					</Bar>
				</customHeader>
				<content>
					<VBox width="100%" alignItems="Center" justifyContent="Center">
						<Text  class="sapUiTinyMargin txt" text="Welcome to Capgemini GenAI Document Translation Agent for SAP"></Text>
							<Text class="txt" text="Translate your documents quickly and easily. We support PDF, Word, Excel and PPT files. Text in images will not be translated."></Text>
						<Text  class="sapUiTinyMargin sapUiMediumMarginBottom txt" text="Get started now by uploading your document(s)!"></Text>
						
							</VBox>
				
							<HBox>
						<u:FileUploader buttonText="Upload" buttonOnly="false" style="Emphasized" id="batchUpload" class="sapUiMediumMarginBegin" width="100%" name="myFileUpload" multiple="true" uploadUrl="upload/"  tooltip="Upload your file to the local server"
							change="handleFileChange"/>
							
							 <Select  items="{languages>/GCPlanguages}"  class="sapUiLargeMarginBegin"  id="batchLanguageSelect" change=".onLanguageSelect">
							 	<core:Item key="" text="" />
                                <core:Item key="{languages>code}" text="{languages>name}" />
        </Select>
							<Button id="batchTranslate" type="Emphasized" class="sapUiMediumMarginBegin" enabled="false" text="Translate" press="onUploadPress"></Button>
							<Button type="Emphasized" class="sapUiLargeMarginBegin" text="Clear all" press="handleClear"></Button>
								<Button type="Emphasized" class="sapUiLargeMarginBegin" text="Refresh" press="handleRefresh"></Button>
						</HBox>
				
					
					<Table alternateRowColors="true" visible="true" id="batchSummaryTable" width="80%" class="sapUiMediumMargin" items="{/files}">
							<headerToolbar>
										<OverflowToolbar>
											<Title text="Document(s) for Translation" level="H2"/>
											<ToolbarSpacer/>
												<SearchField search="onSearch" width="17.5rem"/>
											<Button tooltip="Sort" icon="sap-icon://sort" press="handleSortButtonPressed"/>
											<Button tooltip="Filter" icon="sap-icon://filter" press="handleFilterButtonPressed"/>
											<Button tooltip="Export Translation Log" icon="sap-icon://excel-attachment" press="onExport"/>
										</OverflowToolbar>
									</headerToolbar>
						<columns>
							<Column  hAlign="Center" width="8%">
								<Text text="File Name"/>
							</Column>
							<Column  hAlign="Center" width="8%">
								<Text text="Source Document"/>
							</Column>
							<Column hAlign="Center" width="8%">
								<Text text="Translation Language"/>
							</Column>
								<Column  hAlign="Center" width="8%">
								<Text text="Translated Document"/>
							</Column>
								<Column  hAlign="Center" width="8%">
								<Text text="Progress"/>
							</Column>
								<Column  hAlign="Center" width="8%">
								<Text text="Status"/>
							</Column>
							 <Column hAlign="Center" width="8%">
                    <Text text="Start Time" />
                </Column>
                <Column hAlign="Center" width="8%">
                    <Text text="Completion Time" />
                </Column>
						</columns>
						<items>
							<ColumnListItem>
							 <cells>
                        <Text text="{fileName}" />
                       <Link  text="View Source" href="{sourceFileLink}" target="_blank" visible="{= ${sourceFileLink} ? true : false}" />
                        <Text text="{translationLanguage}" />
                      <Link  text="View Document" href="{translatedDocument}" target="_blank" visible="{= ${translatedDocument} ? true : false}" />
                       <ProgressIndicator width="100%" percentValue="{progress}" displayValue="{progress}%" state="{= ${progress} === 100 ? 'Success' : 'None'}"/>
                      <ObjectStatus text="{status}" state="{= ${status} === 'Complete' ? 'Success' : 'Warning'}"/>
                       <Text text="{startAt}" />
                        <Text text="{completedAt}" />
                    </cells>
							</ColumnListItem>
						</items>
					</Table>
				</content>
			</Page>
		</pages>
	</App>
</mvc:View>